# ============================================
# NovoTechFlow API — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED: app will not start without this.
JWT_SECRET=<64-character-hex-string>

# JWT signing secret for the EXTERNAL read-only API (separate from JWT_SECRET)
# REQUIRED for the /external module. Use a DIFFERENT 64-char hex string than JWT_SECRET.
EXTERNAL_JWT_SECRET=<64-character-hex-string-different-from-JWT_SECRET>

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Docker / PostgreSQL container credentials (used by docker-compose.yml)
DB_USER=novotechflow
DB_PASSWORD=changeme
DB_NAME=novotechflow
